#!/bin/bash
set -e
echo "=================================================="
echo "✅ Установка DFSORT..."
echo "=================================================="
cd /usr/share/dfsort
python3 -m venv venv
venv/bin/pip install --upgrade pip
venv/bin/pip install watchdog pyyaml python-magic schedule croniter questionary
venv/bin/pip install -e .
mkdir -p /var/log/dfsort
echo "=================================================="
echo "✅ DFSORT успешно установлен!"
echo "=================================================="
echo "Для настройки: dfsort --configure"
echo "=================================================="
