#!/bin/bash
set -e

echo "=================================================="
echo "✅ Установка DFSORT..."
echo "=================================================="

# Устанавливаем Python-зависимости
pip3 install schedule croniter questionary 2>/dev/null || true

echo "=================================================="
echo "✅ DFSORT успешно установлен!"
echo "=================================================="
echo "Для настройки: dfsort --configure"
echo "Для запуска: dfsort"
echo "Для запуска в фоне: systemctl --user start dfsort"
echo "=================================================="
